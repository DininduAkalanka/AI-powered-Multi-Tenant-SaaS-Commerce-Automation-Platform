# ─────────────────────────────────────────────────────────────────
# CommercePilot Backend — Environment Variables
# Copy this file to .env and fill in all values
# NEVER commit .env to version control
# ─────────────────────────────────────────────────────────────────

# App
NODE_ENV=development
PORT=3001
APP_NAME=CommercePilot

# ─────────────────────────────────────────────────────────────────
# Database (Docker Postgres + pgvector)
# ─────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://commercepilot:commercepilot_dev_secret@localhost:5432/commercepilot_db?schema=public"
POSTGRES_USER=commercepilot
POSTGRES_PASSWORD=commercepilot_dev_secret
POSTGRES_DB=commercepilot_db

# ─────────────────────────────────────────────────────────────────
# Redis (Docker)
# ─────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379

# ─────────────────────────────────────────────────────────────────
# JWT Authentication
# ─────────────────────────────────────────────────────────────────
JWT_SECRET=CHANGE_ME_USE_LONG_RANDOM_STRING_32_CHARS_MIN
JWT_EXPIRES_IN=7d

# ─────────────────────────────────────────────────────────────────
# AI — Gemini Flash (free via Google AI Studio)
# Get key at: https://aistudio.google.com/app/apikey
# ─────────────────────────────────────────────────────────────────
GEMINI_API_KEY=YOUR_GEMINI_API_KEY_HERE
GEMINI_MODEL=gemini-1.5-flash
GEMINI_EMBEDDING_MODEL=text-embedding-004
GEMINI_MAX_TOKENS=2048
GEMINI_TEMPERATURE=0.1

# ─────────────────────────────────────────────────────────────────
# Email — MailHog (dev, zero config)
# Web UI: http://localhost:8025
# ─────────────────────────────────────────────────────────────────
EMAIL_PROVIDER=mailhog
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@commercepilot.dev
EMAIL_FROM_NAME=CommercePilot

# ─────────────────────────────────────────────────────────────────
# Email — Resend (production — swap EMAIL_PROVIDER to 'resend')
# ─────────────────────────────────────────────────────────────────
RESEND_API_KEY=YOUR_RESEND_KEY_WHEN_READY

# ─────────────────────────────────────────────────────────────────
# WhatsApp — Meta Cloud API (production)
# Leave blank to use the mock simulator
# ─────────────────────────────────────────────────────────────────
WHATSAPP_PROVIDER=mock
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_VERIFY_TOKEN=CHANGE_ME_WEBHOOK_VERIFY_TOKEN
WHATSAPP_API_VERSION=v18.0

# ─────────────────────────────────────────────────────────────────
# WooCommerce Integration — Mock adapter by default
# ─────────────────────────────────────────────────────────────────
WOOCOMMERCE_PROVIDER=mock

# ─────────────────────────────────────────────────────────────────
# Frontend URL (for email links, CORS)
# ─────────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000
